<div class="view view--full">
<div class="flex flex--row h--full" style="padding: 8px 12px;">
  {% assign hours = today %}
  {% assign avg = average %}

  {% if current == nil and hours == nil %}
  <div class="flex flex--center-x flex--center-y grow">
    <div style="font-size: 24px; font-weight: 700; color: #000;">Keine Gym-Daten</div>
  </div>
  {% else %}

  <div class="flex flex--col flex--center-y" style="width: 140px;">
    <div style="font-size: 14px; font-weight: 700; letter-spacing: 1px;">AI FITNESS</div>
    <div style="font-size: 14px; font-weight: 600;">Agnesviertel</div>
    <div style="font-size: 80px; font-weight: 700; line-height: 1; margin: 8px 0;">{{ current.percentage | default: "--" }}%</div>
    <div style="font-size: 16px; font-weight: 700;">
      {% if current.percentage <= 5 %}Fast leer
      {% elsif current.percentage <= 15 %}Ruhig
      {% elsif current.percentage <= 25 %}Moderat
      {% elsif current.percentage <= 40 %}Voll
      {% else %}Sehr voll
      {% endif %}
    </div>
    {% comment %} Beste Zeit: only future hours {% endcomment %}
    {% assign current_hour = 0 %}
    {% if hours and hours.size > 0 %}
      {% assign last_entry = hours | last %}
      {% assign current_hour = last_entry.hour | plus: 1 %}
    {% endif %}
    {% assign best_hour = 0 %}
    {% assign best_avg = 100 %}
    {% for a in avg %}
      {% if a.hour >= current_hour and a.hour <= 20 %}
        {% if a.avg_percentage < best_avg %}
          {% assign best_avg = a.avg_percentage %}
          {% assign best_hour = a.hour %}
        {% endif %}
      {% endif %}
    {% endfor %}
    {% if best_hour > 0 %}
    <div style="font-size: 13px; font-weight: 600; margin-top: 8px; border: 2px solid #000; padding: 4px 8px;">Beste Zeit: {{ best_hour }}:00</div>
    {% endif %}
  </div>

  <div style="flex: 1; padding-left: 8px; height: 100%;">
    {% if avg and avg.size > 0 %}
    {% comment %} Dynamic Y-axis: find max across today + average {% endcomment %}
    {% assign max_val = 0 %}
    {% for h in hours %}
      {% if h.percentage > max_val %}{% assign max_val = h.percentage %}{% endif %}
    {% endfor %}
    {% for a in avg %}
      {% if a.avg_percentage > max_val %}{% assign max_val = a.avg_percentage %}{% endif %}
    {% endfor %}
    {% if max_val < 10 %}{% assign max_val = 10 %}{% endif %}
    {% assign max_pct = max_val | plus: 9 | divided_by: 10 | times: 10 %}

    {% comment %} Data range for dynamic x-axis {% endcomment %}
    {% assign data_end_hour = 7 %}
    {% for h in hours %}
      {% if h.hour > data_end_hour %}{% assign data_end_hour = h.hour %}{% endif %}
    {% endfor %}
    {% for a in avg %}
      {% if a.hour > data_end_hour %}{% assign data_end_hour = a.hour %}{% endif %}
    {% endfor %}
    {% assign axis_x2 = data_end_hour | minus: 7 | times: 25 | plus: 10 %}

    {% comment %} Current time for now-marker {% endcomment %}
    {% assign now_hour = 'now' | date: '%H' | plus: 2 %}
    {% if now_hour > 23 %}{% assign now_hour = now_hour | modulo: 24 %}{% endif %}

    <svg viewBox="-30 0 470 280" style="width:100%;height:100%;display:block;">
      <defs>
        <pattern id="hatch" patternUnits="userSpaceOnUse" width="4" height="4">
          <line x1="0" y1="2" x2="4" y2="2" stroke="#000" stroke-width="0.5"/>
        </pattern>
        <clipPath id="chart-clip"><rect x="-30" y="16" width="500" height="218" /></clipPath>
      </defs>

      {% comment %} Y-axis labels (0% to max_pct%) {% endcomment %}
      {% assign y_top_val = max_pct | times: 210 | divided_by: max_pct %}
      {% assign y_top = 230 | minus: y_top_val | plus: 4 %}
      {% assign y_mid_pct = max_pct | divided_by: 2 %}
      {% assign y_mid_val = y_mid_pct | times: 210 | divided_by: max_pct %}
      {% assign y_mid = 230 | minus: y_mid_val | plus: 4 %}
      <text x="6" y="{{ y_top }}" text-anchor="end" style="font-size: 10px; font-weight: 600;">{{ max_pct }}%</text>
      <text x="6" y="{{ y_mid }}" text-anchor="end" style="font-size: 10px; font-weight: 600;">{{ y_mid_pct }}%</text>
      <text x="6" y="234" text-anchor="end" style="font-size: 10px; font-weight: 600;">0%</text>

      <g clip-path="url(#chart-clip)">
      {% comment %} Average: dashed line, no fill {% endcomment %}
      <polyline fill="none" stroke="#000" stroke-width="1" stroke-dasharray="4,3" points="{% for a in avg %}{% assign ax = a.hour | minus: 7 | times: 25 | plus: 10 %}{% assign ay = a.avg_percentage | times: 210 | divided_by: max_pct %}{% assign apy = 230 | minus: ay %}{{ ax }},{{ apy }} {% endfor %}" />

      {% comment %} Today: area fill + thin line {% endcomment %}
      {% if hours and hours.size > 1 %}
      <polygon fill="url(#hatch)" stroke="none" points="{% for h in hours %}{% assign hx = h.hour | minus: 7 | times: 25 | plus: 10 %}{% assign hy = h.percentage | times: 210 | divided_by: max_pct %}{% assign hpy = 230 | minus: hy %}{{ hx }},{{ hpy }} {% endfor %}{% assign last_hh = hours | last %}{% assign last_hx = last_hh.hour | minus: 7 | times: 25 | plus: 10 %}{{ last_hx }},230 {% assign first_hh = hours | first %}{% assign first_hx = first_hh.hour | minus: 7 | times: 25 | plus: 10 %}{{ first_hx }},230" />
      <polyline fill="none" stroke="#000" stroke-width="1.5" stroke-linejoin="round" stroke-linecap="round" points="{% for h in hours %}{% assign hx = h.hour | minus: 7 | times: 25 | plus: 10 %}{% assign hy = h.percentage | times: 210 | divided_by: max_pct %}{% assign hpy = 230 | minus: hy %}{{ hx }},{{ hpy }} {% endfor %}" />
      {% endif %}

      {% comment %} Current: red dot + percentage label {% endcomment %}
      {% if hours and hours.size > 0 %}
        {% assign last_h = hours | last %}
        {% assign cx = last_h.hour | minus: 7 | times: 25 | plus: 10 %}
        {% assign cy = last_h.percentage | times: 210 | divided_by: max_pct %}
        {% assign cpy = 230 | minus: cy %}
        <circle cx="{{ cx }}" cy="{{ cpy }}" r="5" fill="red" />
        <text x="{{ cx }}" y="{{ cpy | minus: 10 }}" text-anchor="middle" style="font-size: 11px; font-weight: 700;">{{ last_h.percentage }}%</text>
      {% endif %}

      </g>
      {% comment %} Now marker: red dashed vertical line {% endcomment %}
      {% if now_hour >= 7 and now_hour <= data_end_hour %}
        {% assign now_x = now_hour | minus: 7 | times: 25 | plus: 10 %}
        <line x1="{{ now_x }}" y1="20" x2="{{ now_x }}" y2="230" stroke="red" stroke-width="1" stroke-dasharray="4,3" />
      {% endif %}

      {% comment %} X axis (limited to data range) {% endcomment %}
      <line x1="10" y1="231" x2="{{ axis_x2 }}" y2="231" stroke="#000" stroke-width="1.5" />

      {% comment %} Hour ticks (only within data range) {% endcomment %}
      {% for i in (0..5) %}
        {% assign hour = i | times: 3 | plus: 7 %}
        {% if hour <= data_end_hour %}
          {% assign tx = i | times: 3 | times: 25 | plus: 10 %}
          <line x1="{{ tx }}" y1="231" x2="{{ tx }}" y2="237" stroke="#000" stroke-width="1.5" />
          <text x="{{ tx }}" y="255" text-anchor="middle" style="font-size: 14px; font-weight: 600;">{{ hour }}</text>
        {% endif %}
      {% endfor %}

      {% comment %} Legend {% endcomment %}
      <rect x="20" y="268" width="30" height="10" fill="url(#hatch)" stroke="#000" stroke-width="1"/>
      <text x="56" y="279" style="font-size: 11px; font-weight: 600;">Heute</text>
      <line x1="110" y1="275" x2="140" y2="275" stroke="#000" stroke-width="1" stroke-dasharray="4,3" />
      <text x="146" y="279" style="font-size: 11px; font-weight: 600;">Durchschnitt</text>
    </svg>
    {% endif %}
  </div>

  {% endif %}
</div>

  <div class="title_bar">
    <span class="title">AI Fitness</span>
    <span class="instance">{{ updated_at | date: "%H:%M" }}</span>
  </div>
</div>
