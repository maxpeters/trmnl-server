<div class="flex flex--row h--full" style="padding: 8px 12px;">
  <div class="flex flex--col flex--center-y" style="width: 140px;">
    <div style="font-size: 14px; font-weight: 700; letter-spacing: 1px;">AI FITNESS</div>
    <div style="font-size: 14px; font-weight: 600;">Agnesviertel</div>
    <div style="font-size: 80px; font-weight: 700; line-height: 1; margin: 8px 0;">{{ occupancy_pct }}%</div>
    <div style="font-size: 16px; font-weight: 700;">
      {% if occupancy_pct <= 5 %}Fast leer
      {% elsif occupancy_pct <= 15 %}Ruhig
      {% elsif occupancy_pct <= 25 %}Moderat
      {% elsif occupancy_pct <= 40 %}Voll
      {% else %}Sehr voll
      {% endif %}
    </div>
    {% assign best_hour = 0 %}
    {% assign best_avg = 100 %}
    {% for a in average %}
      {% if a.hour >= 8 and a.hour <= 21 %}
        {% if a.avg_percentage < best_avg %}
          {% assign best_avg = a.avg_percentage %}
          {% assign best_hour = a.hour %}
        {% endif %}
      {% endif %}
    {% endfor %}
    {% if best_hour > 0 %}
    <div style="font-size: 13px; font-weight: 600; margin-top: 8px; border: 2px solid #000; padding: 2px 8px;">Beste Zeit: {{ best_hour }}:00</div>
    {% endif %}
  </div>

  <div style="flex: 1; padding-left: 8px; height: 100%;">
    {% assign hours = today %}
    {% assign avg = average %}
    {% if avg and avg.size > 0 %}
    {% assign max_pct = 25 %}
    {% for h in hours %}
      {% if h.percentage > max_pct %}{% assign max_pct = h.percentage %}{% endif %}
    {% endfor %}
    {% for a in avg %}
      {% if a.avg_percentage > max_pct %}{% assign max_pct = a.avg_percentage %}{% endif %}
    {% endfor %}

    <svg viewBox="0 0 440 280" style="width:100%;height:100%;display:block;">
      {% comment %} Average: outline area with dashed border {% endcomment %}
      <polygon fill="none" stroke="#000" stroke-width="1.5" stroke-dasharray="4,3" points="{% for a in avg %}{% assign ax = a.hour | minus: 6 | times: 25 | plus: 10 %}{% assign ay = a.avg_percentage | times: 210 | divided_by: max_pct %}{% assign apy = 230 | minus: ay %}{{ ax }},{{ apy }} {% endfor %}{% assign last_a = avg | last %}{% assign last_ax = last_a.hour | minus: 6 | times: 25 | plus: 10 %}{{ last_ax }},230 {% assign first_a = avg | first %}{% assign first_ax = first_a.hour | minus: 6 | times: 25 | plus: 10 %}{{ first_ax }},230" />

      {% comment %} Today: solid line {% endcomment %}
      {% if hours and hours.size > 1 %}
      <polyline fill="none" stroke="#000" stroke-width="4" stroke-linejoin="round" stroke-linecap="round" points="{% for h in hours %}{% assign hx = h.hour | minus: 6 | times: 25 | plus: 10 %}{% assign hy = h.percentage | times: 210 | divided_by: max_pct %}{% assign hpy = 230 | minus: hy %}{{ hx }},{{ hpy }} {% endfor %}" />
      {% endif %}

      {% comment %} Current position: dot + vertical line + label {% endcomment %}
      {% if current %}
        {% assign cx = current.hour | minus: 6 | times: 25 | plus: 10 %}
        {% assign cy = current.percentage | times: 210 | divided_by: max_pct %}
        {% assign cpy = 230 | minus: cy %}
        <circle cx="{{ cx }}" cy="{{ cpy }}" r="8" fill="#000" />
      {% endif %}

      {% comment %} X axis {% endcomment %}
      <line x1="10" y1="231" x2="440" y2="231" stroke="#000" stroke-width="1.5" />

      {% comment %} Hour ticks {% endcomment %}
      {% for i in (0..5) %}
        {% assign hour = i | times: 3 | plus: 6 %}
        {% assign tx = i | times: 3 | times: 25 | plus: 10 %}
        <line x1="{{ tx }}" y1="231" x2="{{ tx }}" y2="237" stroke="#000" stroke-width="1.5" />
        <text x="{{ tx }}" y="255" text-anchor="middle" style="font-size: 14px; font-weight: 600;">{{ hour }}</text>
      {% endfor %}
    </svg>
    {% endif %}
  </div>
</div>

<div class="title_bar">
  <span class="title">AI Fitness</span>
  <span class="instance">{{ updated_at | date: "%H:%M" }}</span>
</div>
