<div class="view view--half_horizontal">
<div class="layout layout--row" style="padding: 4px 8px; align-items: stretch; justify-content: flex-start;">

  {% if analyses == nil or analyses.size == 0 %}
  <div class="flex flex--center-x flex--center-y grow">
    <div style="font-size: 18px; font-weight: 700; color: #000;">Keine Daten</div>
  </div>
  {% else %}

  {% for plant in analyses %}
  <div class="flex flex--col" style="{% unless forloop.first %}border-left: 2px solid #000; padding-left: 8px;{% endunless %} flex: 1; {% unless forloop.last %}margin-right: 8px;{% endunless %}">
    <div style="font-size: 11px; font-weight: 700; letter-spacing: 1px; color: #000; border-bottom: 1px solid #000; padding-bottom: 2px; margin-bottom: 4px;">{{ plant.sensor_name }}</div>
    {% if plant.latest_reading %}
    <div style="font-size: 32px; font-weight: 700; line-height: 1; color: #000; text-align: center;">{{ plant.latest_reading.moisture }}%</div>
    <div style="border-top: 1px solid #000; padding-top: 3px; margin-top: auto;">
      <div class="flex flex--row flex--between" style="font-size: 11px; font-weight: 600; color: #000;">
        <span>{{ plant.latest_reading.temperature }}°C</span>
        {% if plant.latest_reading.battery <= 10 %}
        <span style="background: red; color: #fff; padding: 0 2px; font-weight: 700;">{{ plant.latest_reading.battery }}%</span>
        {% else %}
        <span>{{ plant.latest_reading.battery }}%</span>
        {% endif %}
      </div>
      {% if plant.prediction %}
      <div class="text--center" style="margin-top: 2px;">
        {% if plant.prediction.status == "dry" %}
        <div style="font-size: 12px; font-weight: 700; background: red; color: #fff; padding: 1px 4px;">GIESSEN!</div>
        {% elsif plant.prediction.days_until_dry <= 1 %}
        <div style="font-size: 11px; font-weight: 700; border: 2px solid #000; padding: 1px 3px;">Bald giessen!</div>
        {% elsif plant.prediction.days_until_dry <= 3 %}
        <div style="font-size: 11px; font-weight: 600; border: 1px solid #000; padding: 1px 3px;">~{{ plant.prediction.days_until_dry | floor }} Tage</div>
        {% else %}
        <div style="font-size: 11px; font-weight: 600;">~{{ plant.prediction.days_until_dry | floor }} Tage OK</div>
        {% endif %}
      </div>
      {% endif %}
    </div>
    {% endif %}
  </div>
  {% endfor %}

  {% endif %}
</div>

<div class="title_bar">
  <span class="title">MiFlora</span>
  <span class="instance">{{ timestamp | date: "%d.%m. %H:%M" }}</span>
</div>
</div>
