<div class="flex flex--row h--full" style="padding: 6px 10px;">

  {% if available == false or sleep == nil %}
  <div class="flex flex--center-x flex--center-y grow">
    <div style="font-size: 18px; font-weight: 700; color: #000;">Keine Daten</div>
  </div>
  {% else %}

  {% assign s = sleep %}

  <!-- Left: Score hero -->
  <div class="flex flex--col flex--center-y" style="width: 120px; text-align: center;">
    <div style="font-size: 11px; font-weight: 700; letter-spacing: 1px; color: #000;">SCHLAF</div>
    <div style="font-size: 32px; font-weight: 700; line-height: 1; color: #000;">
      {% assign total_h = s.total_sleep_min | divided_by: 60 %}
      {% assign total_m = s.total_sleep_min | modulo: 60 %}
      {{ total_h }}h {{ total_m }}m
    </div>
    <div style="font-size: 11px; font-weight: 600; color: #000;">
      {{ s.start_time }} - {{ s.end_time }}
    </div>
    <div style="font-size: 22px; font-weight: 700; line-height: 1; color: #000; margin-top: 4px;">{{ s.sleep_score }}</div>
    <div style="font-size: 10px; font-weight: 700; color: #000;">
      {% if s.sleep_score >= 85 %}Sehr gut
      {% elsif s.sleep_score >= 70 %}Gut
      {% elsif s.sleep_score >= 50 %}Maessig
      {% else %}Schlecht
      {% endif %}
    </div>
  </div>

  <!-- Center: Phase breakdown -->
  <div class="flex flex--col flex--center-y" style="border-left: 2px solid #000; padding-left: 10px; width: 170px;">
    <div style="font-size: 10px; font-weight: 700; letter-spacing: 1px; color: #000; margin-bottom: 4px;">PHASEN</div>

    {% assign deep_h = s.deep_sleep_min | divided_by: 60 %}
    {% assign deep_m = s.deep_sleep_min | modulo: 60 %}
    {% assign deep_pct = s.deep_sleep_min | times: 100 | divided_by: s.total_sleep_min %}
    <div class="flex flex--row flex--between" style="width: 100%; font-size: 13px; font-weight: 600; color: #000; padding: 2px 0; border-bottom: 1px solid #000;">
      <span style="font-weight: 700;">Tief</span>
      <span>{{ deep_h }}h{{ deep_m }}m</span>
      <span style="font-weight: 700;">{{ deep_pct }}%</span>
    </div>

    {% assign light_h = s.light_sleep_min | divided_by: 60 %}
    {% assign light_m = s.light_sleep_min | modulo: 60 %}
    {% assign light_pct = s.light_sleep_min | times: 100 | divided_by: s.total_sleep_min %}
    <div class="flex flex--row flex--between" style="width: 100%; font-size: 13px; font-weight: 600; color: #000; padding: 2px 0; border-bottom: 1px solid #000;">
      <span style="font-weight: 700;">Leicht</span>
      <span>{{ light_h }}h{{ light_m }}m</span>
      <span style="font-weight: 700;">{{ light_pct }}%</span>
    </div>

    {% assign rem_h = s.rem_sleep_min | divided_by: 60 %}
    {% assign rem_m = s.rem_sleep_min | modulo: 60 %}
    {% assign rem_pct = s.rem_sleep_min | times: 100 | divided_by: s.total_sleep_min %}
    <div class="flex flex--row flex--between" style="width: 100%; font-size: 13px; font-weight: 600; color: #000; padding: 2px 0; border-bottom: 1px solid #000;">
      <span style="font-weight: 700;">REM</span>
      <span>{{ rem_h }}h{{ rem_m }}m</span>
      <span style="font-weight: 700;">{{ rem_pct }}%</span>
    </div>

    <div class="flex flex--row flex--between" style="width: 100%; font-size: 13px; font-weight: 600; color: #000; padding: 2px 0;">
      <span style="font-weight: 700;">Wach</span>
      <span>{{ s.awake_min }}m</span>
      {% assign awake_pct = s.awake_min | times: 100 | divided_by: s.total_sleep_min %}
      <span style="font-weight: 700;">{{ awake_pct }}%</span>
    </div>
  </div>

  <!-- Right: Hypnogram -->
  <div class="flex flex--col flex--center-y grow" style="border-left: 2px solid #000; padding-left: 10px;">
    {% assign total_dur = s.total_sleep_min %}
    {% if total_dur and total_dur > 0 and s.phases.size > 0 %}
    <svg viewBox="0 0 200 80" style="width: 100%; height: 100%; display: block;">
      {% assign px = 0 %}
      {% for p in s.phases %}
        {% assign pw = p.duration_min | times: 170 | divided_by: total_dur %}
        {% if pw < 1 %}{% assign pw = 1 %}{% endif %}
        {% if p.phase == "deep" %}{% assign py = 56 %}
        {% elsif p.phase == "light" %}{% assign py = 38 %}
        {% elsif p.phase == "rem" %}{% assign py = 20 %}
        {% else %}{% assign py = 2 %}
        {% endif %}
        <rect x="{{ px }}" y="{{ py }}" width="{{ pw }}" height="14" fill="#000" />
        {% assign px = px | plus: pw %}
      {% endfor %}

      <text x="178" y="12" style="font-size: 7px; font-weight: 700;">W</text>
      <text x="172" y="30" style="font-size: 7px; font-weight: 700;">REM</text>
      <text x="178" y="48" style="font-size: 7px; font-weight: 700;">L</text>
      <text x="178" y="66" style="font-size: 7px; font-weight: 700;">T</text>

      <line x1="0" y1="72" x2="170" y2="72" stroke="#000" stroke-width="0.5" />
      <text x="0" y="79" style="font-size: 7px; font-weight: 600;">{{ s.start_time }}</text>
      <text x="170" y="79" text-anchor="end" style="font-size: 7px; font-weight: 600;">{{ s.end_time }}</text>
    </svg>
    {% endif %}
  </div>

  {% endif %}
</div>

<div class="title_bar">
  <span class="title">Schlaf</span>
  <span class="instance">{{ date }}</span>
</div>
