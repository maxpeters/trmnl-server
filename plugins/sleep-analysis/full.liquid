<div class="view view--full">
<div class="layout layout--col" style="align-items: stretch; padding: 10px 16px;">

  {% if available == false or sleep == nil %}
  <div class="flex flex--center-x flex--center-y grow">
    <div style="font-size: 24px; font-weight: 700; color: #000;">Keine Schlaf-Daten</div>
  </div>
  {% else %}

  {% assign s = sleep %}

  <!-- Top: Score + Duration + Phases compact -->
  <div class="flex flex--row flex--between flex--center-y" style="margin-bottom: 8px;">
    <div class="flex flex--row flex--center-y gap--medium">
      <div>
        <div style="font-size: 40px; font-weight: 700; line-height: 1; color: #000;">
          {% assign total_h = s.total_sleep_min | divided_by: 60 %}
          {% assign total_m = s.total_sleep_min | modulo: 60 %}
          {{ total_h }}h {{ total_m }}m
        </div>
        <div style="font-size: 14px; font-weight: 600; color: #000;">{{ s.start_time }} - {{ s.end_time }}</div>
      </div>
      <div style="border-left: 2px solid #000; padding-left: 12px;">
        <div style="font-size: 36px; font-weight: 700; line-height: 1; color: #000;">{{ s.sleep_score }}</div>
        <div style="font-size: 13px; font-weight: 700; color: #000;">
          {% if s.sleep_score >= 85 %}Sehr gut
          {% elsif s.sleep_score >= 70 %}Gut
          {% elsif s.sleep_score >= 50 %}Maessig
          {% else %}<span style="color: red;">Schlecht</span>
          {% endif %}
        </div>
      </div>
    </div>
    <div class="flex flex--row gap--medium" style="font-size: 13px; font-weight: 600; color: #000;">
      {% assign deep_h = s.deep_sleep_min | divided_by: 60 %}
      {% assign deep_m = s.deep_sleep_min | modulo: 60 %}
      <div style="text-align: center;"><div style="font-size: 18px; font-weight: 700;">{{ deep_h }}h{{ deep_m }}m</div><div>Tief</div></div>
      {% assign light_h = s.light_sleep_min | divided_by: 60 %}
      {% assign light_m = s.light_sleep_min | modulo: 60 %}
      <div style="text-align: center;"><div style="font-size: 18px; font-weight: 700;">{{ light_h }}h{{ light_m }}m</div><div>Leicht</div></div>
      {% assign rem_h = s.rem_sleep_min | divided_by: 60 %}
      {% assign rem_m = s.rem_sleep_min | modulo: 60 %}
      <div style="text-align: center;"><div style="font-size: 18px; font-weight: 700;">{{ rem_h }}h{{ rem_m }}m</div><div>REM</div></div>
      <div style="text-align: center;"><div style="font-size: 18px; font-weight: 700; color: red;">{{ s.awake_min }}m</div><div style="color: red;">Wach</div></div>
    </div>
  </div>

  <!-- Hypnogram: full width -->
  <div class="grow" style="min-height: 0;">
    {% assign total_dur = s.total_sleep_min %}
    {% if total_dur and total_dur > 0 and s.phases.size > 0 %}
    <svg viewBox="0 0 700 250" style="width: 100%; height: 100%; display: block;">
      {% comment %} Y: Wach=20, REM=75, Leicht=130, Tief=185. Bar height=40 {% endcomment %}
      {% assign px = 40 %}
      {% for p in s.phases %}
        {% assign pw = p.duration_min | times: 620 | divided_by: total_dur %}
        {% if pw < 2 %}{% assign pw = 2 %}{% endif %}
        {% if p.phase == "deep" %}{% assign py = 185 %}{% assign pcolor = "#000" %}
        {% elsif p.phase == "light" %}{% assign py = 130 %}{% assign pcolor = "#000" %}
        {% elsif p.phase == "rem" %}{% assign py = 75 %}{% assign pcolor = "#000" %}
        {% else %}{% assign py = 20 %}{% assign pcolor = "red" %}
        {% endif %}
        <rect x="{{ px }}" y="{{ py }}" width="{{ pw }}" height="40" fill="{{ pcolor }}" />
        {% assign px = px | plus: pw %}
      {% endfor %}

      {% comment %} Y axis labels {% endcomment %}
      <text x="35" y="45" text-anchor="end" style="font-size: 14px; font-weight: 700; fill: red;">Wach</text>
      <text x="35" y="100" text-anchor="end" style="font-size: 14px; font-weight: 700;">REM</text>
      <text x="35" y="155" text-anchor="end" style="font-size: 14px; font-weight: 700;">Leicht</text>
      <text x="35" y="210" text-anchor="end" style="font-size: 14px; font-weight: 700;">Tief</text>

      {% comment %} Grid lines {% endcomment %}
      <line x1="40" y1="60" x2="660" y2="60" stroke="#000" stroke-width="0.5" stroke-dasharray="2,4" />
      <line x1="40" y1="115" x2="660" y2="115" stroke="#000" stroke-width="0.5" stroke-dasharray="2,4" />
      <line x1="40" y1="170" x2="660" y2="170" stroke="#000" stroke-width="0.5" stroke-dasharray="2,4" />

      {% comment %} X axis {% endcomment %}
      <line x1="40" y1="228" x2="660" y2="228" stroke="#000" stroke-width="1.5" />
      <text x="40" y="245" style="font-size: 13px; font-weight: 600;">{{ s.start_time }}</text>
      <text x="660" y="245" text-anchor="end" style="font-size: 13px; font-weight: 600;">{{ s.end_time }}</text>
    </svg>
    {% endif %}
  </div>

  {% endif %}
</div>

<div class="title_bar">
  <span class="title">Schlaf</span>
  <span class="instance">{{ sleep.sleep_date | default: date | date: "%d.%m.%Y" }}</span>
</div>
</div>
