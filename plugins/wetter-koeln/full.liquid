<div class="flex flex--col h--full" style="padding: 8px 12px;">

  {% assign w = weather %}
  {% if w.available == false %}
  <div class="flex flex--center-x flex--center-y grow">
    <div style="font-size: 24px; font-weight: 700;">Keine Wetter-Daten</div>
  </div>
  {% else %}

  <!-- Top: Current + Kita -->
  <div class="flex flex--row flex--between flex--center-y" style="margin-bottom: 4px;">
    <div class="flex flex--row flex--center-y gap--small">
      <div style="font-size: 36px; font-weight: 700; line-height: 1; color: #000;">{{ w.current.temp | floor }}°</div>
      <div style="font-size: 13px; font-weight: 600; color: #000;">
        <div>{{ w.current.description }}</div>
        <div>{{ w.daily.today.min | floor }}° / {{ w.daily.today.max | floor }}° · {{ w.daily.today.precipitation_prob }}%</div>
        <div>{{ w.daily.today.sunrise }} - {{ w.daily.today.sunset }}</div>
      </div>
    </div>
    {% if w.bike_forecast %}
    <div style="border: 2px solid #000; padding: 4px 8px;{% if w.bike_forecast.status == 'wet' %} background: #000; color: #fff;{% endif %}">
      <div style="font-size: 11px; font-weight: 700;">{{ w.bike_forecast.label }}</div>
      <div style="font-size: 13px; font-weight: 700;">{{ w.bike_forecast.message }}</div>
    </div>
    {% endif %}
  </div>

  <!-- Chart: full width below -->
  <div class="grow" style="min-height: 0; border-top: 1px solid #000; padding-top: 4px;">
    {% assign hourly = w.hourly %}
    {% if hourly and hourly.size > 0 %}

    {% assign min_temp = 100 %}
    {% assign max_temp = -50 %}
    {% for h in hourly %}
      {% assign t = h.temp | floor %}
      {% if t < min_temp %}{% assign min_temp = t %}{% endif %}
      {% if t > max_temp %}{% assign max_temp = t %}{% endif %}
    {% endfor %}
    {% assign temp_range = max_temp | minus: min_temp %}
    {% if temp_range == 0 %}{% assign temp_range = 1 %}{% endif %}

    <svg viewBox="0 0 700 250" style="width: 100%; height: 100%; display: block;">
      <rect x="{{ 8 | times: 29 | plus: 10 }}" y="0" width="29" height="200" fill="#000" opacity="0.06" />
      <text x="{{ 8 | times: 29 | plus: 24 }}" y="12" text-anchor="middle" style="font-size: 8px; font-weight: 700;">BRING</text>
      <rect x="{{ 15 | times: 29 | plus: 10 }}" y="0" width="58" height="200" fill="#000" opacity="0.06" />
      <text x="{{ 15 | times: 29 | plus: 39 }}" y="12" text-anchor="middle" style="font-size: 8px; font-weight: 700;">ABHOL</text>

      {% for h in hourly %}
        {% assign i = forloop.index0 %}
        {% assign bx = i | times: 29 | plus: 10 %}
        {% assign bh = h.precipitation_prob %}
        {% assign by = 200 | minus: bh %}
        {% if h.precipitation_prob > 5 %}
        <rect x="{{ bx }}" y="{{ by }}" width="22" height="{{ bh }}" fill="#000" opacity="0.2" />
        {% endif %}
        {% if h.precipitation_prob > 40 %}
        <text x="{{ bx | plus: 11 }}" y="{{ by | minus: 3 }}" text-anchor="middle" style="font-size: 8px; font-weight: 700;">{{ h.precipitation_prob }}%</text>
        {% endif %}
      {% endfor %}

      <polyline fill="none" stroke="#000" stroke-width="3" stroke-linejoin="round" points="{% for h in hourly %}{% assign i = forloop.index0 %}{% assign px = i | times: 29 | plus: 21 %}{% assign t = h.temp | floor %}{% assign ty = t | minus: min_temp | times: 150 | divided_by: temp_range %}{% assign py = 190 | minus: ty %}{{ px }},{{ py }} {% endfor %}" />

      {% for h in hourly %}
        {% assign i = forloop.index0 %}
        {% assign mod3 = i | modulo: 3 %}
        {% if mod3 == 0 %}
          {% assign px = i | times: 29 | plus: 21 %}
          {% assign t = h.temp | floor %}
          {% assign ty = t | minus: min_temp | times: 150 | divided_by: temp_range %}
          {% assign py = 190 | minus: ty | minus: 8 %}
          <text x="{{ px }}" y="{{ py }}" text-anchor="middle" style="font-size: 10px; font-weight: 700;">{{ t }}°</text>
        {% endif %}
      {% endfor %}

      <line x1="10" y1="201" x2="700" y2="201" stroke="#000" stroke-width="1" />
      {% for i in (0..7) %}
        {% assign hour = i | times: 3 %}
        {% assign tx = hour | times: 29 | plus: 21 %}
        <text x="{{ tx }}" y="218" text-anchor="middle" style="font-size: 10px; font-weight: 600;">{{ hour }}</text>
      {% endfor %}

      <line x1="20" y1="240" x2="45" y2="240" stroke="#000" stroke-width="3" />
      <text x="50" y="243" style="font-size: 9px; font-weight: 600;">Temp</text>
      <rect x="100" y="234" width="12" height="12" fill="#000" opacity="0.2" />
      <text x="116" y="243" style="font-size: 9px; font-weight: 600;">Regen%</text>
      <rect x="180" y="234" width="12" height="12" fill="#000" opacity="0.08" />
      <text x="196" y="243" style="font-size: 9px; font-weight: 600;">Kita</text>
    </svg>
    {% endif %}
  </div>

  {% endif %}
</div>

<div class="title_bar">
  <span class="title">Wetter Koeln</span>
  <span class="instance">{{ weather.updated_at | date: "%H:%M" }}</span>
</div>
