<div class="flex flex--col h--full" style="padding: 8px 12px;">

  {% if available == false %}
  <div class="flex flex--center-x flex--center-y grow">
    <div style="font-size: 24px; font-weight: 700;">Keine Wetter-Daten</div>
  </div>
  {% else %}

  <!-- Top: Current + Kita -->
  <div class="flex flex--row flex--between flex--center-y" style="margin-bottom: 4px;">
    <div class="flex flex--row flex--center-y gap--small">
      <div style="font-size: 36px; font-weight: 700; line-height: 1; color: #000;">{{ current.temp | floor }}°</div>
      <div style="font-size: 13px; font-weight: 600; color: #000;">
        <div>{{ current.description }}</div>
        <div>{{ daily.today.min | floor }}° / {{ daily.today.max | floor }}° · {{ daily.today.precipitation_prob }}%</div>
        <div>{{ daily.today.sunrise }} - {{ daily.today.sunset }}</div>
      </div>
    </div>
    {% if bike_forecast %}
    <div style="border: 2px solid #000; padding: 4px 8px;{% if bike_forecast.status == 'wet' %} background: red; color: #fff;{% endif %}">
      <div style="font-size: 11px; font-weight: 700;">{{ bike_forecast.label }}</div>
      <div style="font-size: 13px; font-weight: 700;">{{ bike_forecast.message }}</div>
    </div>
    {% endif %}
  </div>

  <!-- Chart -->
  <div class="grow" style="min-height: 0; border-top: 1px solid #000; padding-top: 4px;">
    {% if hourly and hourly.size > 0 %}

    {% assign min_temp = 100 %}
    {% assign max_temp = -50 %}
    {% for h in hourly %}
      {% assign t = h.temp | floor %}
      {% if t < min_temp %}{% assign min_temp = t %}{% endif %}
      {% if t > max_temp %}{% assign max_temp = t %}{% endif %}
    {% endfor %}
    {% assign temp_range = max_temp | minus: min_temp %}
    {% if temp_range == 0 %}{% assign temp_range = 1 %}{% endif %}

    {% assign first_time = hourly[0].time | split: ":" %}
    {% assign start_hour = first_time[0] | plus: 0 %}
    {% assign chart_hours = hourly.size %}
    {% assign px_per_hour = 29 %}
    {% assign chart_left = 10 %}

    <svg viewBox="0 0 710 250" style="width: 100%; height: 100%; display: block;">
      <defs>
        <pattern id="dots" width="6" height="6" patternUnits="userSpaceOnUse">
          <circle cx="2" cy="2" r="1.2" fill="#000" />
        </pattern>
      </defs>

      {% comment %} Kita time slots - positioned by actual hour {% endcomment %}
      {% for slot in (0..3) %}
        {% case slot %}
          {% when 0 %}{% assign slot_h = 8 %}{% assign slot_m = 0 %}{% assign slot_dur = 22 %}{% assign slot_label = "BRING" %}
          {% when 1 %}{% assign slot_h = 9 %}{% assign slot_m = 15 %}{% assign slot_dur = 15 %}{% assign slot_label = "" %}
          {% when 2 %}{% assign slot_h = 14 %}{% assign slot_m = 20 %}{% assign slot_dur = 12 %}{% assign slot_label = "ABHOL" %}
          {% when 3 %}{% assign slot_h = 15 %}{% assign slot_m = 15 %}{% assign slot_dur = 15 %}{% assign slot_label = "" %}
        {% endcase %}
        {% assign offset = slot_h | minus: start_hour %}
        {% if offset < 0 %}{% assign offset = offset | plus: 24 %}{% endif %}
        {% if offset < chart_hours %}
          {% assign sx = offset | times: px_per_hour | plus: chart_left | plus: slot_m | divided_by: 2 %}
          {% assign sw = slot_dur | divided_by: 2 %}
          {% if sw < 8 %}{% assign sw = 8 %}{% endif %}
          <rect x="{{ sx }}" y="16" width="{{ sw }}" height="184" fill="url(#dots)" opacity="0.5" />
          {% if slot_label != "" %}
            <text x="{{ sx | plus: 5 }}" y="12" style="font-size: 8px; font-weight: 700;">{{ slot_label }}</text>
          {% endif %}
        {% endif %}
      {% endfor %}

      {% comment %} Precipitation bars {% endcomment %}
      {% for h in hourly %}
        {% assign i = forloop.index0 %}
        {% assign bx = i | times: px_per_hour | plus: chart_left %}
        {% if h.precipitation_prob > 5 %}
          {% assign bh = h.precipitation_prob %}
          {% assign by = 200 | minus: bh %}
          <rect x="{{ bx }}" y="{{ by }}" width="22" height="{{ bh }}" fill="none" stroke="#000" stroke-width="1.5" />
          {% if h.precipitation_prob > 40 %}
            <text x="{{ bx | plus: 11 }}" y="{{ by | minus: 3 }}" text-anchor="middle" style="font-size: 8px; font-weight: 700;">{{ h.precipitation_prob }}%</text>
          {% endif %}
        {% endif %}
      {% endfor %}

      {% comment %} Temperature line {% endcomment %}
      <polyline fill="none" stroke="#000" stroke-width="3" stroke-linejoin="round" points="{% for h in hourly %}{% assign i = forloop.index0 %}{% assign px = i | times: px_per_hour | plus: chart_left | plus: 11 %}{% assign t = h.temp | floor %}{% assign ty = t | minus: min_temp | times: 150 | divided_by: temp_range %}{% assign py = 190 | minus: ty %}{{ px }},{{ py }} {% endfor %}" />

      {% comment %} Temperature labels every 3h {% endcomment %}
      {% for h in hourly %}
        {% assign i = forloop.index0 %}
        {% if i == 0 or forloop.index0 | modulo: 3 == 0 %}
          {% assign px = i | times: px_per_hour | plus: chart_left | plus: 11 %}
          {% assign t = h.temp | floor %}
          {% assign ty = t | minus: min_temp | times: 150 | divided_by: temp_range %}
          {% assign py = 190 | minus: ty | minus: 8 %}
          <text x="{{ px }}" y="{{ py }}" text-anchor="middle" style="font-size: 10px; font-weight: 700;">{{ t }}°</text>
        {% endif %}
      {% endfor %}

      {% comment %} X-axis with actual hours {% endcomment %}
      <line x1="{{ chart_left }}" y1="201" x2="700" y2="201" stroke="#000" stroke-width="1" />
      {% for h in hourly %}
        {% assign i = forloop.index0 %}
        {% assign mod3 = i | modulo: 3 %}
        {% if mod3 == 0 %}
          {% assign tx = i | times: px_per_hour | plus: chart_left | plus: 11 %}
          {% assign hour_parts = h.time | split: ":" %}
          <text x="{{ tx }}" y="218" text-anchor="middle" style="font-size: 10px; font-weight: 600;">{{ hour_parts[0] | plus: 0 }}</text>
        {% endif %}
      {% endfor %}

      {% comment %} Legend {% endcomment %}
      <line x1="20" y1="240" x2="45" y2="240" stroke="#000" stroke-width="3" />
      <text x="50" y="243" style="font-size: 9px; font-weight: 600;">Temp</text>
      <rect x="100" y="234" width="12" height="12" fill="none" stroke="#000" stroke-width="1.5" />
      <text x="116" y="243" style="font-size: 9px; font-weight: 600;">Regen%</text>
      <rect x="180" y="234" width="12" height="12" fill="url(#dots)" opacity="0.5" />
      <text x="196" y="243" style="font-size: 9px; font-weight: 600;">Kita</text>
    </svg>
    {% endif %}
  </div>

  {% endif %}
</div>

<div class="title_bar">
  <span class="title">Wetter Koeln</span>
  <span class="instance">{{ updated_at | date: "%H:%M" }}</span>
</div>
